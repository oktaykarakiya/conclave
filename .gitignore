# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
# Tool caches are relocated under .cache/ via pyproject (ruff cache-dir, mypy/pytest
# cache_dir) to keep the repo root tidy. The bare entries remain as a safety net in
# case a tool is ever invoked without that config.
.cache/
.mypy_cache/
.ruff_cache/
.pytest_cache/
dist/
build/

# Conclave runtime state (never commit a real data dir)
.conclave-home/
*.db
*.db-wal
*.db-shm

# Node / frontend
node_modules/
frontend/dist/
# NOTE: the built SPA under src/conclave/web/static/ IS committed so the daemon
# serves the UI without needing Node at runtime (only frontend dev needs Node).

# Env / secrets
.env
*.local

# Claude Code local working state (worktrees, etc.)
.claude/
