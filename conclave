#!/usr/bin/env bash
# Conclave launcher: bootstraps a local venv on first run, then starts the daemon.
# Usage:
#   ./conclave                                   # serves on 0.0.0.0:8700
#   CONCLAVE_HOST=127.0.0.1 ./conclave           # restrict to loopback
#   CONCLAVE_PORT=9000 ./conclave                # custom port
#   CONCLAVE_HOME=/path/to/data ./conclave       # data dir (default ~/.local/share/conclave)
#   CONCLAVE_ENGINE=claude ./conclave            # use the legacy claude CLI (default: opencode)
#   CONCLAVE_OPENCODE_BIN=/path/to/opencode      # override opencode binary autodiscovery
#   PYTHON=python3.12 ./conclave                 # pick the interpreter used to build the venv
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
VENV="$HERE/.venv"
PYTHON="${PYTHON:-python3}"

if [ ! -x "$VENV/bin/python" ]; then
  if ! "$PYTHON" -c 'import sys; sys.exit(0 if sys.version_info >= (3, 12) else 1)' 2>/dev/null; then
    echo "[conclave] error: Python >= 3.12 is required (found: $("$PYTHON" --version 2>&1))." >&2
    echo "[conclave] install Python 3.12+ or run: PYTHON=python3.12 ./conclave" >&2
    exit 1
  fi
  echo "[conclave] creating virtualenv at $VENV ..."
  "$PYTHON" -m venv "$VENV"
  "$VENV/bin/python" -m pip install --quiet --upgrade pip
fi

# Install/refresh the package if it is missing or pyproject is newer than the marker.
MARKER="$VENV/.conclave-installed"
if [ ! -f "$MARKER" ] || [ "$HERE/pyproject.toml" -nt "$MARKER" ]; then
  echo "[conclave] installing dependencies ..."
  "$VENV/bin/python" -m pip install --quiet -e "$HERE"
  touch "$MARKER"
fi

# --- Engine selection (opencode-native by default) ---------------------------
# Conclave drives the opencode CLI by default; CONCLAVE_ENGINE=claude uses the legacy one.
export CONCLAVE_ENGINE="${CONCLAVE_ENGINE:-opencode}"
if [ "$CONCLAVE_ENGINE" = "opencode" ]; then
  # opencode is frequently installed outside PATH (e.g. ~/.opencode/bin). Locate it once.
  if [ -z "${CONCLAVE_OPENCODE_BIN:-}" ]; then
    if command -v opencode >/dev/null 2>&1; then
      CONCLAVE_OPENCODE_BIN="$(command -v opencode)"
    elif [ -x "$HOME/.opencode/bin/opencode" ]; then
      CONCLAVE_OPENCODE_BIN="$HOME/.opencode/bin/opencode"
    fi
    export CONCLAVE_OPENCODE_BIN
  fi
  if [ -n "${CONCLAVE_OPENCODE_BIN:-}" ]; then
    echo "[conclave] engine: opencode ($CONCLAVE_OPENCODE_BIN)" >&2
  else
    echo "[conclave] warning: opencode not found — install it or set CONCLAVE_OPENCODE_BIN," >&2
    echo "[conclave]          or run 'CONCLAVE_ENGINE=claude ./conclave' for the claude CLI." >&2
  fi
fi

exec "$VENV/bin/python" -m conclave.main "$@"
